# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=encrypted-relay.db
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# Database Encryption - REQUIRED for production
# Generate using: openssl rand -hex 32
# Must be exactly 64 characters (32 bytes) in hex format
DATABASE_MASTER_KEY=your_64_character_hex_key_here_replace_this_value

# JWT Configuration
JWT_SECRET=secure_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Server Key Configuration
EXPIRE_PRIVATE_KEY_IN=24h
ROTATION_CUTOFF=1h